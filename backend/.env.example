# Quand tu passeras à la vraie API HaveIBeenPwned, ta clé ira ici
HIBP_API_KEY=
PORT=3001

# Connexion PostgreSQL (Supabase > Project Settings > Database > Connection string > Session pooler)
DATABASE_URL=

# Secret utilisé pour signer les tokens de connexion — mets une vraie valeur aléatoire en prod
JWT_SECRET=

# SendGrid (emails de réinitialisation de mot de passe et d'invitation)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# URL du frontend, utilisée pour construire les liens dans les emails
FRONTEND_URL=http://localhost:5173

# Email du compte qui peut changer librement de plan depuis le dashboard (pour tester le rendu de chaque plan)
ADMIN_EMAIL=

# Stripe (paiement des plans Pro/Famille) — clés de test d'abord (sk_test_..., whsec_test_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_FAMILLE=
