# Quand tu passeras à la vraie API HaveIBeenPwned, ta clé ira ici
HIBP_API_KEY=
PORT=3001

# Connexion PostgreSQL (Supabase > Project Settings > Database > Connection string > Session pooler)
DATABASE_URL=

# Secret utilisé pour signer les tokens de connexion — mets une vraie valeur aléatoire en prod
JWT_SECRET=
