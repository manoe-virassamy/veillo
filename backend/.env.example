# Quand tu passeras à la vraie API HaveIBeenPwned, ta clé ira ici
HIBP_API_KEY=
PORT=3001

# Connexion PostgreSQL (Supabase > Project Settings > Database > Connection string > Session pooler)
DATABASE_URL=

# Secret utilisé pour signer les tokens de connexion — mets une vraie valeur aléatoire en prod
JWT_SECRET=

# SendGrid (emails de réinitialisation de mot de passe et d'invitation)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

# URL du frontend, utilisée pour construire les liens dans les emails
FRONTEND_URL=http://localhost:5173

# Email du compte qui peut changer librement de plan depuis le dashboard (pour tester le rendu de chaque plan)
ADMIN_EMAIL=

# Stripe (paiement des plans Personnel/Famille) — clés de test d'abord (sk_test_..., whsec_test_...)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# 6 Price ID (Product catalog Stripe)
STRIPE_PRICE_PERSONNEL_BETA=
STRIPE_PRICE_PERSONNEL_MONTHLY=
STRIPE_PRICE_PERSONNEL_YEARLY=
STRIPE_PRICE_FAMILLE_BETA=
STRIPE_PRICE_FAMILLE_MONTHLY=
STRIPE_PRICE_FAMILLE_YEARLY=

# 2 Coupon ID (duration "once", appliqués sur la 1ère facture des offres standard mensuelles)
STRIPE_COUPON_PERSONNEL_FIRST_MONTH=
STRIPE_COUPON_FAMILLE_FIRST_MONTH=
